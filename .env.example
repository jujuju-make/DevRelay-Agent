# --- Application ---
APP_NAME=DevRelay-Agent
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database (MySQL) ---
DATABASE_URL=mysql+aiomysql://root:你的密码@localhost:3306/devrelay_db

# --- Redis (Memurai / Redis) ---
REDIS_URL=redis://localhost:6379/0
CHAT_HISTORY_TTL_SECONDS=86400
CHAT_HISTORY_KEY_PREFIX=devrelay:chat:

# --- LLM (OpenAI 兼容 API，如 DeepSeek / 阿里云 DashScope) ---
OPENAI_API_KEY=sk-your-api-key
OPENAI_API_BASE=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# --- External Tools ---
GITHUB_TOKEN=ghp_your_github_token
GITHUB_API_BASE=https://api.github.com
SERPER_API_KEY=your_serper_api_key

# --- Optional (reserved) ---
CHROMA_DB_PATH=./chroma_db
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
